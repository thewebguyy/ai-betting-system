# =============================================================================
# AI BETTING INTELLIGENCE SYSTEM — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── App General ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-32-random-chars
APP_HOST=0.0.0.0
APP_PORT=8000

# ── JWT Auth (personal use) ───────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080        # 7 days
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./db/betting.db
# For PostgreSQL (Supabase): uncomment and fill below
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis (local free instance) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ── Sports Data APIs (all free plans) ────────────────────────────────────────
API_FOOTBALL_KEY=your_api_football_key_here        # rapidapi.com/api-sports
ODDS_API_KEY=your_odds_api_key_here                # the-odds-api.com (500 req/mo free)
THESPORTSDB_API_KEY=2                              # free public key = "2"
BALLDONTLIE_API_KEY=                               # no key needed for basic endpoints

# ── AI Provider Keys ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key          # aistudio.google.com — free
ANTHROPIC_API_KEY=your_anthropic_api_key           # claude.ai — free tier
OPENAI_API_KEY=your_openai_key                     # needed only for DeepSeek compat endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_deepseek_api_key             # platform.deepseek.com — cheap/free

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token         # BotFather on Telegram
TELEGRAM_CHAT_ID=your_chat_id                      # your personal chat id

# ── Email (SendGrid — 100 emails/day free) ────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# ── Betting Parameters ────────────────────────────────────────────────────────
DEFAULT_BANKROLL=1000.0         # starting bankroll in your currency
KELLY_FRACTION=0.25             # fractional Kelly multiplier (0.25 = quarter Kelly)
MIN_EV_THRESHOLD=0.05           # alert when EV > 5%
MIN_VALUE_THRESHOLD=0.05        # model_prob > implied_prob + 5%
ODDS_LINE_MOVE_ALERT=0.10       # alert when line moves > 10%
DEFAULT_VIG_MARGIN=0.05         # assumed vig margin for normalization
