{
    "version": 2,
    "builds": [
        {
            "src": "dashboard/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dashboard/build"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/(auth|health|odds|value-bets|analytics|bankroll|bets|matches|reports)",
            "destination": "https://ai-betting-system-production.up.railway.app/$1"
        },
        {
            "source": "/(auth|health|odds|value-bets|analytics|bankroll|bets|matches|reports)/:path*",
            "destination": "https://ai-betting-system-production.up.railway.app/$1/:path*"
        },
        {
            "source": "/static/:path*",
            "destination": "/static/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ]
}